rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function unchangedProtectedFields() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['id', 'role', 'createdAt']);
    }

    function validBaseProfile(userId, role) {
      return isSelf(userId)
        && request.resource.data.id == userId
        && request.resource.data.role == role
        && request.resource.data.email is string
        && request.resource.data.name is string
        && request.resource.data.lastName is string
        && request.resource.data.createdAt is string;
    }

    match /patients/{patientId} {
      allow create: if validBaseProfile(patientId, 'patient');
      allow read: if isSelf(patientId)
        || (signedIn() && resource.data.caregiverId == request.auth.uid);
      allow update: if isSelf(patientId) && unchangedProtectedFields();
      allow delete: if false;
    }

    match /caregivers/{caregiverId} {
      allow create: if validBaseProfile(caregiverId, 'caregiver');
      allow read: if isSelf(caregiverId);
      allow update: if isSelf(caregiverId) && unchangedProtectedFields();
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
